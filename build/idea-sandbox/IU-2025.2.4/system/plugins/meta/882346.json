{"id":882346,"xmlId":"com.intellij.bigdatatools.core","name":"Big Data Tools Core","description":"<p>The Core plugin is required for any plugin from the Big Data Tools bundle.\n    It will be installed with all plugins from the <a href=\"https://plugins.jetbrains.com/bundles/8-big-data-tools\">Big Data Tools</a> bundle:\n    <a href=\"https://plugins.jetbrains.com/plugin/21704-kafka\">Kafka</a>,\n    <a href=\"https://plugins.jetbrains.com/plugin/21706-remote-file-systems\">Remote File Systems</a>,\n    <a href=\"https://plugins.jetbrains.com/plugin/21673-zeppelin\">Zeppelin</a>,\n    <a href=\"https://plugins.jetbrains.com/plugin/21701-big-data-file-viewer\">Big Data File Viewer</a>,\n    <a href=\"https://plugins.jetbrains.com/plugin/21700-spark\">Spark</a>,\n    <a href=\"https://plugins.jetbrains.com/plugin/21702-flink\">Flink</a>.</p>","organization":"JetBrains s.r.o.","tags":["Tools Integration","Data Science"],"version":"252.27397.103","dependencies":["com.intellij.modules.ultimate","intellij.charts","intellij.platform.navbar.backend","intellij.grid.csv.core.impl","intellij.grid.impl","intellij.grid.core.impl","intellij.grid.plugin"],"optionalDependencies":["com.intellij.database","com.intellij.modules.python"],"since":"252.27397","until":"252.*","size":57037865,"vendor":"JetBrains"}